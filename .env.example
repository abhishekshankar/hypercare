# Real environment variables are introduced per ticket. Do not commit secrets.

# TASK-003 — populated by `cdk deploy` output + `docs/infra-runbook.md`
# Use SSM port forward (scripts/db-tunnel.sh); default local port is 15432.
#
# TASK-004 — migrations may use `hypercare_admin`; the running app should use
# `hypercare_app` + the dedicated Secrets Manager secret (ARN recorded after PM bootstrap).
# See docs/infra-runbook.md § "Application database role (hypercare_app)".
# DATABASE_URL=postgres://hypercare_app:<password>@localhost:15432/hypercare_dev
# DATABASE_SECRET_ARN=
# AWS_REGION=ca-central-1

# --- Bedrock (optional overrides; TASK-008 / 009 / 010) + eval harness (TASK-012; uses same DB/Bedrock when live) ---
# RAG + safety use Claude Haiku 4.5 via system inference profile ids (us.*) by default in package config.
# BEDROCK_ANSWER_MODEL_ID=
# BEDROCK_CLASSIFIER_MODEL_ID=
# MODEL_ROUTING=             # TASK-042: 1 = Layer-5 policy routing + `model_routing_decisions` rows (pair with migrated cohort column)
# EVAL_LIVE=                 # 1 = @hypercare/eval uses real DB + Bedrock; unset = offline fixtures (docs/adr/0011)
# EVAL_USER_ID=              # optional user id for live answer eval (care_profile / loadStage)

# --- TASK-006 (apps/web) — Cognito + session (see docs/auth-contract.md) ---
# Copy these into `apps/web/.env.local` for local dev. Never commit the client secret.
#
# All values in docs/auth-contract.md; AUTH_BASE_URL / AUTH_SIGNOUT_URL must match Cognito-allowed callback/sign-out URLs.
#
# COGNITO_USER_POOL_ID=
# COGNITO_APP_CLIENT_ID=
# COGNITO_APP_CLIENT_SECRET=   # server-only: use Secrets Manager in deployed env (see docs/auth-runbook.md)
# COGNITO_DOMAIN=              # Hosted UI base URL, e.g. https://....amazoncognito.com
# COGNITO_REGION=ca-central-1
# AUTH_BASE_URL=               # e.g. http://localhost:3000 — no trailing slash; used for /api/auth/callback
# AUTH_SIGNOUT_URL=            # e.g. http://localhost:3000 (must match an allowed *sign-out* URL; prod may be root only)
# SESSION_COOKIE_SECRET=       # 32+ bytes. Generate: openssl rand -base64 32

# --- TASK-040 — progressive lesson card transport (pair server + `apps/web` NEXT_PUBLIC_*) ---
# STREAMING_LESSONS=1
# NEXT_PUBLIC_STREAMING_LESSONS=1
