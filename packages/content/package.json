    "test": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1034.0",
    "@hypercare/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
