{
  "name": "@alongside/model-router",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "lint": "eslint src test --max-warnings 0",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit && node ../../node_modules/typescript/lib/tsc.js -p tsconfig.test.json --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "yaml": "^2.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
