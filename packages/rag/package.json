{
  "name": "@hypercare/rag",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-prompts.mjs",
    "lint": "eslint src test --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "bedrock-check": "tsx scripts/bedrock-check.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1034.0",
    "@hypercare/content": "workspace:*",
    "@hypercare/db": "workspace:*",
    "@hypercare/safety": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
